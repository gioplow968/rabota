import matplotlib.pyplot as plt
from matplotlib.pyplot import xlabel, ylabel

x = [1,1,1,1,2,2,3,3,3,4,5,5,5,5,6,6,6,7,7]

counts,bins,patches = plt.hist(x, bins=7,edgecolor = "black",linewidth = 2)

for i,j in zip(patches,counts):
    if j > 2:
        i.set_facecolor("green")
    else:
        i.set_facecolor("red")


plt.title("Гистограма Акций")
ylabel("Количество")
xlabel("День")
plt.legend("green",labels = "Покупка")
plt.show()
